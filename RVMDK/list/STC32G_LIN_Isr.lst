    5          #include  "STC32G_LIN.h"
    6          
    7          bit LinRxFlag;
    8          
    9          //========================================================================
   10          // 函数: LIN_ISR_Handler
   11          // 描述: LIN中断函数.
   12          // 参数: none.
   13          // 返回: none.
   14          // 版本: V1.0, 2022-03-28
   15          //========================================================================
   16          void LIN_ISR_Handler (void) interrupt LIN_VECTOR
   17          {
   18   1        u8 isr;
   19   1        u8 arTemp;
   20   1        arTemp = LINAR;     //LINAR 现场保存，避免主循环里写完 LINAR 后产生中断，在中断里
             -修改了 LINAR 内容
   21   1        
   22   1        isr = LinReadReg(LSR);    //读取寄存器清除状态标志位
   23   1        if((isr & 0x03) == 0x03)
   24   1        {
   25   2          isr = LinReadReg(LER);
   26   2          if(isr == 0x00)   //No Error
   27   2          {
   28   3            LinRxFlag = 1;
   29   3          }
   30   2        }
   31   1        else
   32   1        {
   33   2          isr = LinReadReg(LER);  //读取清除错误寄存器
   34   2        }
   35   1      
   36   1        LINAR = arTemp;    //LINAR 现场恢复
   37   1      }
