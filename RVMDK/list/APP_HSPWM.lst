   82   1      
   83   1        PWMx_InitStructure.PWM_EnoSelect= ENO1P|ENO1N|ENO2P|ENO2N|ENO3P|ENO3N|ENO4P|ENO4N;  //输出通道选择,
             -  ENO1P,ENO1N,ENO2P,ENO2N,ENO3P,ENO3N,ENO4P,ENO4N / ENO5P,ENO6P,ENO7P,ENO8P
   84   1        PWMx_InitStructure.PWM_Period   = 2047;             //周期时间,   0~65535
   85   1        PWMx_InitStructure.PWM_DeadTime = 0;                //死区发生器设置, 0~255
   86   1        PWMx_InitStructure.PWM_MainOutEnable= ENABLE;       //主输出使能, ENABLE,DISABLE
   87   1        PWMx_InitStructure.PWM_CEN_Enable   = ENABLE;       //使能计数器, ENABLE,DISABLE
   88   1        HSPWM_Configuration(PWMA, &PWMx_InitStructure, &PWMA_Duty);       //初始化PWM通用寄存器,  PWMA,PWMB
   89   1        PWMx_InitStructure.PWM_EnoSelect= ENO5P|ENO6P|ENO7P|ENO8P;  //输出通道选择, ENO1P,ENO1N,ENO2P,ENO2N
             -,ENO3P,ENO3N,ENO4P,ENO4N / ENO5P,ENO6P,ENO7P,ENO8P
   90   1        HSPWM_Configuration(PWMB, &PWMx_InitStructure, &PWMB_Duty);       //初始化PWM通用寄存器,  PWMA,PWMB
   91   1      
   92   1        PWM1_USE_P60P61();
   93   1        PWM2_USE_P62P63();
   94   1        PWM3_USE_P64P65();
   95   1        PWM4_USE_P66P67();
   96   1      
   97   1        PWM5_USE_P74();
