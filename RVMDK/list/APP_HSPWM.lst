   99   1        PWM7_USE_P76();
  100   1        PWM8_USE_P77();
  101   1        
  102   1        P4_MODE_IO_PU(GPIO_Pin_0);      //P4.0 设置为准双向口
  103   1        NVIC_PWM_Init(PWMA,DISABLE,Priority_0);
  104   1        NVIC_PWM_Init(PWMB,DISABLE,Priority_0);
