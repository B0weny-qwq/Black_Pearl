   39   1        DMA_M2M_RXAL = (u8)(DMA->DMA_Rx_Buffer);
   40   1        DMA_M2M_TXAH = (u8)(DMA->DMA_Tx_Buffer>>8);
   41   1        DMA_M2M_TXAL = (u8)(DMA->DMA_Tx_Buffer);
