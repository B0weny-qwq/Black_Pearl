   43   1        DMA_M2M_AMTH = (u8)(DMA->DMA_Length>>8);  //设置传输总字节数(高8位)：n+1
   44   1        
   45   1        if(DMA->DMA_SRC_Dir == M2M_ADDR_DEC)    DMA_M2M_CFG |= 0x20;  //数据读完后地址自减
   46   1        else DMA_M2M_CFG &= ~0x20;  //数据读完后地址自减
   47   1        if(DMA->DMA_DEST_Dir == M2M_ADDR_DEC)   DMA_M2M_CFG |= 0x10;  //数据写入后地址自减
   48   1        else DMA_M2M_CFG &= ~0x10;  //数据写入后地址自减
   49   1        
   50   1        if(DMA->DMA_Enable == ENABLE)   DMA_M2M_CR |= 0x80; //使能M2M DMA
   51   1        else DMA_M2M_CR &= ~0x80; //禁止M2M DMA
   52   1      }
