   18          //========================================================================
   19          void I2C_Init(I2C_InitTypeDef *I2Cx)
   20          {
   21   1        if(I2Cx->I2C_Mode == I2C_Mode_Master)
   22   1        {
   23   2          I2C_Master();     //设为主机  
   24   2          I2CMSST = 0x00;   //清除I2C主机状态寄存器
   25   2          I2C_SetSpeed(I2Cx->I2C_Speed);
   26   2          if(I2Cx->I2C_MS_WDTA == ENABLE)   I2C_WDTA_EN();  //使能自动发送
   27   2          else                  I2C_WDTA_DIS(); //禁止自动发送
   28   2        }
   29   1        else
   30   1        {
   31   2          I2C_Slave();  //设为从机
   32   2          I2CSLST = 0x00;   //清除I2C从机状态寄存器
   33   2          I2C_Address(I2Cx->I2C_SL_ADR);
   34   2          if(I2Cx->I2C_SL_MA == ENABLE)   I2C_MATCH_EN(); //从机地址比较功能，只接受相匹配地址
   35   2          else                  I2C_MATCH_DIS();  //禁止从机地址比较功能，接受所有设备地址
   36   2        }
   37   1        
   38   1        I2C_Function(I2Cx->I2C_Enable);
   39   1      }
