    6           * @version v1.0
    7           *
    8           * @details
    9           * - 实现陀螺仪与地磁三轴数据的软件低通滤波
   10           * - 采用一阶 IIR + Q8 定点整数状态，避免使用浮点运算
   11           * - 分别维护 gyro / mag 两套独立滤波状态，互不干扰
   12           * - 导出函数：Filter_ResetGyroLowPass() / Filter_ResetMagLowPass() /
   13           *             Filter_GyroLowPass() / Filter_MagLowPass()
   14           *
   15           * @note    首帧有效数据直接灌入状态，保证首次输出等于输入
   16           * @note    无效帧与空指针直接返回 -1，不会污染内部状态
   17           *
   18           * @see     Code_boweny/Function/Filter/Filter.h
   19           */
   20          
   21          #include "Filter.h"
   22          
   23          #define FILTER_LPF_SCALE            ((int32)1L << FILTER_LPF_STATE_Q)
   24          #define FILTER_DATA_IS_ZERO(x,y,z)  (((x) == 0) && ((y) == 0) && ((z) == 0))
   25          #define FILTER_DATA_IS_INVALID(x,y,z)  (((x) == -1) && ((y) == -1) && ((z) == -1))
   26          
   27          typedef struct
   28          {
   29              int32 state_x;
   30              int32 state_y;
   31              int32 state_z;
   32              u8 initialized;
   33          } Filter_LowPass3Axis;
   34          
   35          static Filter_LowPass3Axis filter_gyro_ctx;
   36          static Filter_LowPass3Axis filter_mag_ctx;
   37          
   38          /**
   39           * @brief      复位单个三轴低通状态
   40           * @param[out] ctx  指向三轴滤波状态的指针
   41           * @return     none
   42           *
   43           * @details 驱动内部使用，不对外暴露。
   44           */
   45          static void Filter_ResetState(Filter_LowPass3Axis *ctx)
   46          {
   47   1          if (ctx == 0) {
   48   2              return;
   49   2          }
   50   1      
   51   1          ctx->state_x = 0;
   52   1          ctx->state_y = 0;
   53   1          ctx->state_z = 0;
   54   1          ctx->initialized = 0;
   55   1      }
   56          
