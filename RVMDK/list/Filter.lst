   57          /**
   58           * @brief      更新单轴低通状态
   59           * @param[out] state  指向单轴 Q 格式状态的指针
   60           * @param[in]  input  原始输入值
   61           * @param[in]  shift  平滑系数移位值
   62           * @return     滤波后的 int16 输出
   63           *
   64           * @details 采用一阶 IIR 低通，不对外暴露。
   65           */
   66          static int16 Filter_UpdateAxis(int32 *state, int16 input, u8 shift)
   67          {
   68   1          int32 target;
   69   1      
   70   1          target = (int32)input * FILTER_LPF_SCALE;
   71   1          *state += ((target - *state) >> shift);
   72   1          return (int16)(*state >> FILTER_LPF_STATE_Q);
   73   1      }
   74          
   75          /**
   76           * @brief      对三轴数据执行通用低通处理
   77           * @param[out] ctx    指向目标滤波状态的指针
   78           * @param[in]  shift  平滑系数移位值
   79           * @param[in]  in_x   原始 X 轴输入
   80           * @param[in]  in_y   原始 Y 轴输入
   81           * @param[in]  in_z   原始 Z 轴输入
   82           * @param[out] out_x  指向滤波后 X 轴输出的指针
   83           * @param[out] out_y  指向滤波后 Y 轴输出的指针
   84           * @param[out] out_z  指向滤波后 Z 轴输出的指针
   85           * @return     0=成功，-1=空指针或输入帧无效
   86           *
   87           * @details
   88           * 首帧有效数据直接作为输出并灌入状态。
   89           * 后续帧按固定点一阶 IIR 低通更新。
   90           */
   91          static s8 Filter_LowPassApply(Filter_LowPass3Axis *ctx, u8 shift,
   92                                        int16 in_x, int16 in_y, int16 in_z,
   93                                        int16 *out_x, int16 *out_y, int16 *out_z)
   94          {
   95   1          if ((ctx == 0) || (out_x == 0) || (out_y == 0) || (out_z == 0)) {
   96   2              return -1;
   97   2          }
   98   1      
   99   1          if (FILTER_DATA_IS_ZERO(in_x, in_y, in_z) ||
  100   1              FILTER_DATA_IS_INVALID(in_x, in_y, in_z)) {
  101   2              return -1;
  102   2          }
  103   1      
  104   1          if (!ctx->initialized) {
  105   2              ctx->state_x = (int32)in_x * FILTER_LPF_SCALE;
  106   2              ctx->state_y = (int32)in_y * FILTER_LPF_SCALE;
  107   2              ctx->state_z = (int32)in_z * FILTER_LPF_SCALE;
  108   2              ctx->initialized = 1;
  109   2      
  110   2              *out_x = in_x;
  111   2              *out_y = in_y;
  112   2              *out_z = in_z;
  113   2              return 0;
  114   2          }
  115   1      
  116   1          *out_x = Filter_UpdateAxis(&ctx->state_x, in_x, shift);
  117   1          *out_y = Filter_UpdateAxis(&ctx->state_y, in_y, shift);
  118   1          *out_z = Filter_UpdateAxis(&ctx->state_z, in_z, shift);
  119   1      
  120   1          return 0;
  121   1      }
