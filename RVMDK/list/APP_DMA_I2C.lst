  122          // еҮҪж•°: I2cGetAddress
  123          // жҸҸиҝ°: и®Ўз®—еҗ„з§Қиҫ“е…Ҙж–№ејҸзҡ„ең°еқҖ.
  124          // еҸӮж•°: ж— .
  125          // иҝ”еӣһ: 8дҪҚEEPROMең°еқҖ.
  126          // зүҲжң¬: V1.0, 2013-6-6
  127          //========================================================================
  128          static u8 I2cGetAddress(void)
  129          {
  130   1          u8 address;
  131   1          u8  i,j;
  132   1          
  133   1          address = 0;
  134   1          if((RX2_Buffer[2] == '0') && (RX2_Buffer[3] == 'X'))
  135   1          {
  136   2              for(i=4; i<6; i++)
  137   2              {
  138   3                  j = I2cCheckData(RX2_Buffer[i]);
  139   3                  if(j >= 0x10)   return 0;  //error
  140   3                  address = (address << 4) + j;
  141   3              }
  142   2              return (address);
  143   2          }
  144   1          return  0; //error
  145   1      }
  146          
  147          //========================================================================
  148          // еҮҪж•°: I2cGetDataLength
  149          // жҸҸиҝ°: иҺ·еҸ–иҰҒиҜ»еҮәж•°жҚ®зҡ„еӯ—иҠӮж•°.
  150          // еҸӮж•°: ж— .
  151          // иҝ”еӣһ: 1иҰҒиҜ»еҮәж•°жҚ®зҡ„еӯ—иҠӮж•°.
  152          // зүҲжң¬: V1.0, 2013-6-6
  153          //========================================================================
  154          static u8 I2cGetDataLength(void)
  155          {
  156   1        u8  i;
  157   1        u8  length;
  158   1        
  159   1        length = 0;
  160   1        for(i=7; i<COM2.RX_Cnt; i++)
  161   1        {
  162   2          if(I2cCheckData(RX2_Buffer[i]) >= 10)  break;
  163   2          length = length * 10 + I2cCheckData(RX2_Buffer[i]);
  164   2        }
  165   1        return (length);
  166   1      }
