  107          // еҮҪж•°: I2cCheckData
  108          // жҸҸиҝ°: ж•°жҚ®ж ЎйӘҢеҮҪж•°.
  109          // еҸӮж•°: None.
  110          // иҝ”еӣһ: None.
  111          // зүҲжң¬: V1.0, 2020-09-28
  112          //========================================================================
  113          static u8 I2cCheckData(u8 dat)
  114          {
  115   1        if((dat >= '0') && (dat <= '9'))    return (dat-'0');
  116   1        if((dat >= 'A') && (dat <= 'F'))    return (dat-'A'+10);
C251 COMPILER V5.60.0,  APP_DMA_I2C                                                        27/04/26  00:55:20  PAGE 3   

  117   1        if((dat >= 'a') && (dat <= 'f'))    return (dat-'a'+10);
  118   1        return 0xff;
  119   1      }
