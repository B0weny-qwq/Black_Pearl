  238          void WriteNbyte(u8 addr, u8 number)  /*  WordAddress,First Data Address,Byte lenth   */
  239          {
  240   1        while(Get_MSBusy_Status());    //жЈҖжҹҘI2CжҺ§еҲ¶еҷЁеҝҷзўҢзҠ¶жҖҒ
