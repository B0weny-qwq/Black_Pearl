  319          // 函数: ReadPWMA(void)
  320          // 描述: 异步读取PWMA特殊功能寄存器函数. 
  321          // 参数: addr: 读取特殊功能寄存器地址.
  322          // 返回: dat:  读取特殊功能寄存器内容.
  323          // 版本: V1.0, 2022-03-16
  324          //========================================================================
  325          u8 ReadPWMA(u8 addr)
  326          {
  327   1        u8 dat;
  328   1        
  329   1        while (HSPWMA_ADR & 0x80); //等待前一个异步读写完成
  330   1        HSPWMA_ADR = addr | 0x80;  //设置间接访问地址,只需要设置原XFR地址的低7位
  331   1                      //HSPWMA_ADDR寄存器的最高位写1,表示读数据
  332   1        while (HSPWMA_ADR & 0x80); //等待当前异步读取完成
  333   1        dat = HSPWMA_DAT;      //读取异步数据
  334   1        
  335   1        return dat;
  336   1      }
  337          
