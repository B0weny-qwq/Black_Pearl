  358          //========================================================================
  359          // 函数: WritePWMA(void)
  360          // 描述: 异步读取PWMA特殊功能寄存器函数. 
  361          // 参数: addr: 写入特殊功能寄存器地址.
  362          // 参数: dat:  写入特殊功能寄存器内容.
  363          // 返回: none.
  364          // 版本: V1.0, 2022-03-16
  365          //========================================================================
  366          void WritePWMA(u8 addr, u8 dat)
  367          {
  368   1        while (HSPWMA_ADR & 0x80); //等待前一个异步读写完成
  369   1        HSPWMA_DAT = dat;      //准备需要写入的数据
  370   1        HSPWMA_ADR = addr & 0x7f;  //设置间接访问地址,只需要设置原XFR地址的低7位
  371   1                      //HSPWMA_ADDR寄存器的最高位写0,表示写数据
  372   1      }
