  391          // 函数: HSPWM_Configuration
  392          // 描述: HSPWM初始化程序.
  393          // 参数: PWMx: 结构参数,请参考PWM.h里的定义.
  394          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
  395          // 版本: V1.0, 2022-04-05
  396          //========================================================================
  397          void HSPWM_Configuration(u8 PWM, HSPWMx_InitDefine *PWMx, PWMx_Duty *DUTYx)
  398          {
  399   1        u8 tmpENO,tmpCCER1,tmpCCER2;
  400   1        
  401   1        if(PWM == PWMA)
  402   1        {
  403   2          HSPWMA_CFG = 0x03;      //使能PWMA相关寄存器异步访问功能
  404   2      
  405   2          if(PWMx->PWM_EnoSelect & ENO1P)
  406   2          {
  407   3            tmpENO |= ENO1P;
  408   3            tmpCCER1 |= 0x01;
  409   3          }
  410   2          else
  411   2          {
  412   3            tmpENO &= ~ENO1P;
  413   3            tmpCCER1 &= ~0x01;
  414   3          }
  415   2          if(PWMx->PWM_EnoSelect & ENO1N)
  416   2          {
  417   3            tmpENO |= ENO1N;
