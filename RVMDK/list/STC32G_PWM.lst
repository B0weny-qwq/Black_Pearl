  349   1        while (HSPWMB_ADR & 0x80); //等待前一个异步读写完成
  350   1        HSPWMB_ADR = addr | 0x80;  //设置间接访问地址,只需要设置原XFR地址的低7位
  351   1                      //HSPWMB_ADDR寄存器的最高位写1,表示读数据
  352   1        while (HSPWMB_ADR & 0x80); //等待当前异步读取完成
  353   1        dat = HSPWMB_DAT;      //读取异步数据
