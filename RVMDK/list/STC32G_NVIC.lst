  296          // зүҲжң¬: V1.0, 2020-09-29
  297          //========================================================================
  298          u8 NVIC_RTC_Init(u8 State, u8 Priority)
  299          {
  300   1        if(Priority <= Priority_3) RTC_Priority(Priority); else  return FAIL;
  301   1        RTC_Interrupt(State); 
  302   1        return SUCCESS;
  303   1      }
