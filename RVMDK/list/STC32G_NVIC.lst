  658          // еҮҪж•°: NVIC_CAN_Init
  659          // жҸҸиҝ°: CANеөҢеҘ—еҗ‘йҮҸдёӯж–ӯжҺ§еҲ¶еҷЁеҲқе§ӢеҢ–.
  660          // еҸӮж•°: Channel:  йҖҡйҒ“, CAN1/CAN2.
  661          // еҸӮж•°: State:    дёӯж–ӯдҪҝиғҪзҠ¶жҖҒ, ENABLE/DISABLE.
  662          // еҸӮж•°: Priority: дёӯж–ӯдјҳе…Ҳзә§, Priority_0,Priority_1,Priority_2,Priority_3.
  663          // иҝ”еӣһ: жү§иЎҢз»“жһң SUCCESS/FAIL.
  664          // зүҲжң¬: V1.0, 2023-03-27
  665          //========================================================================
  666          #ifndef CAN1
  667          #define CAN1  0
  668          #endif
  669          #ifndef CAN2
  670          #define CAN2  1
  671          #endif
  672          u8 NVIC_CAN_Init(u8 Channel, u8 State, u8 Priority)
  673          {
  674   1        if(Channel > CAN2) return FAIL;
  675   1        if(Priority > Priority_3) return FAIL;
  676   1        switch(Channel)
  677   1        {
  678   2          case CAN1:
  679   2            if(State == ENABLE)
  680   2              CANIE = 1;    //bit7 1:Enable Interrupt
  681   2            else
  682   2              CANIE = 0;    //bit7 0:Disable Interrupt
  683   2            CAN1_Priority(Priority);
  684   2          break;
  685   2      
  686   2          case CAN2:
  687   2            if(State == ENABLE)
  688   2              CAN2IE = 1;   //bit7 1:Enable Interrupt
  689   2            else
  690   2              CAN2IE = 0;   //bit7 0:Disable Interrupt
  691   2            CAN2_Priority(Priority);
  692   2          break;
  693   2      
  694   2          default:
  695   2            return FAIL;
  696   2          break;
  697   2        }
  698   1        return SUCCESS;
  699   1      }
