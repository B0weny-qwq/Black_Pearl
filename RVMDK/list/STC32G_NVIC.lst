  345          // еҮҪж•°: NVIC_DMA_ADC_Init
  346          // жҸҸиҝ°: DMA ADCеөҢеҘ—еҗ‘йҮҸдёӯж–ӯжҺ§еҲ¶еҷЁеҲқе§ӢеҢ–.
  347          // еҸӮж•°: State:    дёӯж–ӯдҪҝиғҪзҠ¶жҖҒ, ENABLE/DISABLE.
  348          // еҸӮж•°: Priority: дёӯж–ӯдјҳе…Ҳзә§, Priority_0,Priority_1,Priority_2,Priority_3.
  349          // еҸӮж•°: Bus_Priority: ж•°жҚ®жҖ»зәҝи®ҝй—®дјҳе…Ҳзә§, Priority_0,Priority_1,Priority_2,Priority_3.
  350          // иҝ”еӣһ: жү§иЎҢз»“жһң SUCCESS/FAIL.
  351          // зүҲжң¬: V1.0, 2021-05-21
  352          //========================================================================
  353          u8 NVIC_DMA_ADC_Init(u8 State, u8 Priority, u8 Bus_Priority)
  354          {
  355   1        DMA_ADC_CFG &= ~0x0f;
  356   1        if(Priority <= Priority_3) DMA_ADC_CFG |= Priority << 2;
  357   1        if(Bus_Priority <= Priority_3) DMA_ADC_CFG |= Bus_Priority; //ж•°жҚ®жҖ»зәҝи®ҝй—®дјҳе…Ҳзә§
  358   1        if(State == ENABLE)
  359   1          DMA_ADC_CFG |= 0x80;    //bit7 1:Enable Interrupt
  360   1        else
  361   1          DMA_ADC_CFG &= ~0x80;   //bit7 0:Disable Interrupt
  362   1        return SUCCESS;
  363   1      }
