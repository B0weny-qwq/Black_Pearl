  179          //========================================================================
  180          u8 NVIC_CMP_Init(u8 State, u8 Priority)
  181          {
  182   1        if(State & RISING_EDGE) PIE = 1;      //е…Ғи®ёдёҠеҚҮжІҝдёӯж–ӯ
  183   1        else  PIE = 0;      //зҰҒжӯўдёҠеҚҮжІҝдёӯж–ӯ
  184   1        if(State & FALLING_EDGE)  NIE = 1;    //е…Ғи®ёдёӢйҷҚжІҝдёӯж–ӯ
  185   1        else  NIE = 0;      //зҰҒжӯўдёҠеҚҮжІҝдёӯж–ӯ
  186   1        if(Priority <= Priority_3) CMP_Priority(Priority); else  return FAIL;
  187   1        return SUCCESS;
  188   1      }
