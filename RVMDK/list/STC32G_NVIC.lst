  306          // еҮҪж•°: NVIC_PWM_Init
  307          // жҸҸиҝ°: PWMеөҢеҘ—еҗ‘йҮҸдёӯж–ӯжҺ§еҲ¶еҷЁеҲқе§ӢеҢ–.
  308          // еҸӮж•°: Channel:  йҖҡйҒ“, PWMA/PWMB.
  309          // еҸӮж•°: State:    дёӯж–ӯдҪҝиғҪзҠ¶жҖҒ, PWM_BIE/PWM_TIE/PWM_COMIE/PWM_CC8IE~PWM_CC1IE/PWM_UIE/DISABLE.
  310          // еҸӮж•°: Priority: дёӯж–ӯдјҳе…Ҳзә§, Priority_0,Priority_1,Priority_2,Priority_3.
  311          // иҝ”еӣһ: жү§иЎҢз»“жһң SUCCESS/FAIL.
  312          // зүҲжң¬: V1.0, 2020-09-29
  313          //========================================================================
  314          #ifndef PWMA
  315          #define PWMA  9
  316          #endif
  317          #ifndef PWMB
  318          #define PWMB  10
  319          #endif
C251 COMPILER V5.60.0,  STC32G_NVIC                                                        27/04/26  00:55:21  PAGE 6   

  320          u8 NVIC_PWM_Init(u8 Channel, u8 State, u8 Priority)
  321          {
  322   1        if(Channel > PWMB) return FAIL;
  323   1        if(Priority > Priority_3) return FAIL;
  324   1        switch(Channel)
  325   1        {
  326   2          case PWMA:
  327   2            PWMA_IER = State;
  328   2            PWMA_Priority(Priority);
  329   2          break;
  330   2      
  331   2          case PWMB:
  332   2            PWMB_IER = State;
  333   2            PWMB_Priority(Priority);
  334   2          break;
  335   2      
  336   2          default:
  337   2            PWMB_IER = State;
  338   2            Priority = NULL;
  339   2          break;
  340   2        }
  341   1        return SUCCESS;
  342   1      }
