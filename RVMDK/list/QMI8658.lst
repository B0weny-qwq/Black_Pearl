  155          /**
  156           * @brief   执行 I2C 总线恢复
  157           * @return  none
  158           *
  159           * @details
  160           * 当 SDA 或 SCL 被从机意外拉低时，尝试恢复总线。
  161           * 禁用 I2C 模块，将 P1.4/P1.5 切为 GPIO 开漏，
  162           * 手动发送 9 个时钟脉冲迫使从机释放 SDA，最后发送 STOP。
  163           *
  164           * @note    此函数直接操作引脚，适用于 I2C 总线死锁场景
  165           */
  166          void QMI8658_BusRecover(void)
  167          {
  168   1          LOGD("IMU", "bus recover start");
  169   1      
  170   1          I2C_Function(DISABLE);
  171   1          I2C_Master();
  172   1      
  173   1          P1_MODE_OUT_OD(GPIO_Pin_4 | GPIO_Pin_5);
  174   1          P1_PULL_UP_ENABLE(GPIO_Pin_4 | GPIO_Pin_5);
  175   1      
  176   1          {
  177   2              u8 i;
  178   2              for (i = 0; i < 9; i++) {
  179   3                  P15 = 0;
  180   3                  QMI8658_Delay_ms(1);
  181   3                  P15 = 1;
  182   3                  QMI8658_Delay_ms(1);
  183   3                  if (P14 == 1) break;
  184   3              }
  185   2              P14 = 1;
  186   2              QMI8658_Delay_ms(1);
  187   2          }
  188   1      
C251 COMPILER V5.60.0,  QMI8658                                                            27/04/26  00:55:24  PAGE 4   

  189   1          P1_MODE_OUT_OD(GPIO_Pin_4 | GPIO_Pin_5);
  190   1          I2C_Function(ENABLE);
  191   1          I2C_Master();
  192   1      
  193   1          LOGI("IMU", "bus recover done");
  194   1      }
