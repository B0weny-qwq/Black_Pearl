   80           */
   81          static u8 QMI8658_ReadReg(u8 reg_addr)
   82          {
   83   1          u8 i2c_addr_w = QMI8658_I2C_WRITE(QMI8658_I2C_Addr);
   84   1          u8 reg_val = 0xFF;
   85   1      
   86   1          I2C_ReadNbyte(i2c_addr_w, reg_addr, &reg_val, 1);
   87   1      
   88   1          if (Get_MSBusy_Status()) {
   89   2              LOGE("IMU", "RD NACK reg=0x%02X", reg_addr);
   90   2              return 0xFF;
   91   2          }
   92   1          return reg_val;
   93   1      }
   94          
   95          /**
   96           * @brief      连续读取多字节数据 (地址自动递增)
   97           * @param[in]  start_reg  起始寄存器地址
