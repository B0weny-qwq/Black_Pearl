   65   1          if (Get_MSBusy_Status()) {
   66   2              LOGW("IMU", "WR NACK reg=0x%02X val=0x%02X", reg_addr, reg_val);
   67   2              return 1;
   68   2          }
   69   1          return 0;
   70   1      }
