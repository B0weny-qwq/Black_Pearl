  237   3                       ax, ay, az, status0, QMI8658_REG_AX_L);
  238   3              }
  239   2              invalid_latched = 1;
  240   2              return -1;
  241   2          }
  242   1      
  243   1          invalid_latched = 0;
  244   1          *x = ax;
  245   1          *y = ay;
  246   1          *z = az;
  247   1      
