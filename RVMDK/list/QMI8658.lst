   59          static u8 QMI8658_WriteReg(u8 reg_addr, u8 reg_val)
   60          {
   61   1          u8 i2c_addr = QMI8658_I2C_WRITE(QMI8658_I2C_Addr);
   62   1      
   63   1          I2C_WriteNbyte(i2c_addr, reg_addr, &reg_val, 1);
