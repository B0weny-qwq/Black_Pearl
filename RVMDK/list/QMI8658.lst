  105           */
  106          static u8 QMI8658_ReadNByte(u8 start_reg, u8 *buf, u8 len)
  107          {
  108   1          u8 i2c_addr_w = QMI8658_I2C_WRITE(QMI8658_I2C_Addr);
  109   1      
  110   1          I2C_ReadNbyte(i2c_addr_w, start_reg, buf, len);
  111   1      
  112   1          if (Get_MSBusy_Status()) {
  113   2              LOGE("IMU", "RNB NACK reg=0x%02X len=%u", start_reg, len);
  114   2              return 1;
  115   2          }
  116   1          return 0;
  117   1      }
