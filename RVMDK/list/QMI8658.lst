  130          /**
  131           * @brief      探测有效 I2C 地址
  132           * @param[in]  addr  要探测的 7 位 I2C 地址
  133           * @return     0=该地址有设备响应，1=无响应
  134           *
  135           * @details
  136           * 发送 START + 设备写地址，检测是否有 ACK。
  137           */
  138          static u8 QMI8658_ProbeAddr(u8 addr)
  139          {
  140   1          u8 i2c_addr = QMI8658_I2C_WRITE(addr);
  141   1          u8 dummy = QMI8658_REG_WHO_AM_I;
  142   1      
  143   1          I2C_WriteNbyte(i2c_addr, QMI8658_REG_WHO_AM_I, &dummy, 0);
  144   1      
  145   1          if (Get_MSBusy_Status()) {
  146   2              return 1;  /* NACK: 无设备 */
  147   2          }
  148   1          return 0;  /* ACK: 有设备 */
  149   1      }
