  499   1               QMI8658_I2C_WRITE(QMI8658_I2C_ADDR_ALT));
  500   1      
  501   1          /*---------------------------- 地址探测 ----------------------------*/
  502   1          for (retry = 0; retry < 3; retry++) {
  503   2              QMI8658_I2C_Addr = QMI8658_I2C_ADDR_PRIMARY;
  504   2              LOGD("IMU", "probe primary 0x%02X try=%u",
  505   2                   QMI8658_I2C_WRITE(QMI8658_I2C_Addr), retry + 1);
  506   2              if (QMI8658_ProbeAddr(QMI8658_I2C_ADDR_PRIMARY) == 0) {
  507   3                  LOGD("IMU", "found device at primary addr=0x%02X",
  508   3                       QMI8658_I2C_WRITE(QMI8658_I2C_Addr));
  509   3                  break;
  510   3              }
  511   2      
  512   2              LOGW("IMU", "primary addr no ACK, try alt");
  513   2              QMI8658_I2C_Addr = QMI8658_I2C_ADDR_ALT;
  514   2              LOGD("IMU", "probe alt 0x%02X",
  515   2                   QMI8658_I2C_WRITE(QMI8658_I2C_Addr));
  516   2              if (QMI8658_ProbeAddr(QMI8658_I2C_ADDR_ALT) == 0) {
  517   3                  LOGD("IMU", "found device at alt addr=0x%02X",
  518   3                       QMI8658_I2C_WRITE(QMI8658_I2C_Addr));
C251 COMPILER V5.60.0,  QMI8658                                                            27/04/26  00:55:24  PAGE 9   

  519   3                  break;
  520   3              }
  521   2      
  522   2              QMI8658_I2C_Addr = QMI8658_I2C_ADDR_PRIMARY;
  523   2              LOGW("IMU", "addr probe fail try=%u, wait 200ms retry", retry + 1);
  524   2              QMI8658_Delay_ms(200);
  525   2          }
  526   1      
  527   1          if (retry >= 3) {
  528   2              LOGE("IMU", "no device found after 3 tries");
  529   2              return -1;
  530   2          }
  531   1      
  532   1          /*---------------------------- 上电等待 ----------------------------*/
  533   1          LOGD("IMU", "power-up wait %ums", QMI8658_PWR_UP_DELAY_MS);
  534   1          QMI8658_Delay_ms(QMI8658_PWR_UP_DELAY_MS);
