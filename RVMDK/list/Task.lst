   67          //========================================================================
   68          // 函数: Task_Handler_Callback
   69          // 描述: 任务标记回调函数.
   70          // 参数: None.
   71          // 返回: None.
   72          // 版本: V1.0, 2012-10-22
   73          //========================================================================
   74          void Task_Marks_Handler_Callback(void)
   75          {
   76   1        u8 i;
   77   1        for(i=0; i<Tasks_Max; i++)
   78   1        {
   79   2          if(Task_Comps[i].TIMCount)    /* If the time is not 0 */
   80   2          {
   81   3            Task_Comps[i].TIMCount--;  /* Time counter decrement */
   82   3            if(Task_Comps[i].TIMCount == 0)  /* If time arrives */
   83   3            {
   84   4              /*Resume the timer value and try again */
   85   4              Task_Comps[i].TIMCount = Task_Comps[i].TRITime;  
   86   4              Task_Comps[i].Run = 1;    /* The task can be run */
   87   4            }
   88   3          }
   89   2        }
   90   1      }
   91          
   92          //========================================================================
   93          // 函数: Task_Pro_Handler_Callback
   94          // 描述: 任务处理回调函数.
   95          // 参数: None.
   96          // 返回: None.
   97          // 版本: V1.0, 2012-10-22
   98          //========================================================================
   99          void Task_Pro_Handler_Callback(void)
  100          {
  101   1        u8 i;
  102   1        for(i=0; i<Tasks_Max; i++)
  103   1        {
  104   2          if(Task_Comps[i].Run) /* If task can be run */
  105   2          {
  106   3            Task_Comps[i].Run = 0;    /* Flag clear 0 */
  107   3            Task_Comps[i].TaskHook();  /* Run task */
  108   3          }
  109   2        }
  110   1      }
