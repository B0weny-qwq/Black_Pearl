   62          void SPI_WriteByte(u8 dat)    //SPI发送一个字节数据
   63          {
   64   1        if(ESPI)
   65   1        {
   66   2          B_SPI_Busy = 1;
   67   2          SPDAT = dat;
   68   2          while(B_SPI_Busy);  //中断模式
   69   2        }
   70   1        else
   71   1        {
   72   2          SPDAT = dat;
   73   2          while(SPIF == 0); //查询模式
   74   2          SPI_ClearFlag();   //清除SPIF和WCOL标志
   75   2        }
   76   1      }
   77          
   78          //========================================================================
