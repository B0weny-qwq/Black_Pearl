  311          void LinSetHeadDelay(u8 base_ms, u8 prescaler)
  312          {
  313   1        u16 tmp;
  314   1        tmp = (MAIN_Fosc * base_ms) / 1000;
  315   1        LinWriteReg(HDRH,(u8)(tmp>>8));
