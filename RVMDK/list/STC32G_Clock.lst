    8          //========================================================================
    9          // 函数: void HIRCClkConfig(u8 div)
   10          // 描述: 高速IRC时钟初始化程序.
   11          // 参数: div: 时钟分频系数.
   12          // 返回: none.
   13          // 版本: V1.0, 2022-04-03
   14          //========================================================================
   15          void HIRCClkConfig(u8 div)
   16          {
   17   1        HIRCCR = 0x80; //启动内部 IRC
   18   1        while (!(HIRCCR & 1)); //等待时钟稳定
   19   1        CLKDIV = div;
   20   1        CLKSEL = 0x00; //选择内部 IRC ( 默认 )
   21   1      }
   22          
   23          //========================================================================
   24          // 函数: void XOSCClkConfig(u8 div)
   25          // 描述: 外部晶振时钟初始化程序.
   26          // 参数: div: 时钟分频系数.
   27          // 返回: none.
   28          // 版本: V1.0, 2022-04-03
   29          //========================================================================
   30          void XOSCClkConfig(u8 div)
   31          {
   32   1        XOSCCR = 0xc0; //启动外部晶振
   33   1        while (!(XOSCCR & 1)); //等待时钟稳定
   34   1        CLKDIV = div;  //时钟分频
   35   1        CLKSEL = 0x01; //选择外部晶振
   36   1      }
   37          
   38          //========================================================================
   39          // 函数: void IRC32KClkConfig(u8 div)
   40          // 描述: 低速32K IRC时钟初始化程序.
   41          // 参数: div: 时钟分频系数.
   42          // 返回: none.
   43          // 版本: V1.0, 2022-04-03
   44          //========================================================================
   45          void IRC32KClkConfig(u8 div)
   46          {
   47   1        IRC32KCR = 0x80; //启动内部 32K IRC
   48   1        while (!(IRC32KCR & 1)); //等待时钟稳定
   49   1        CLKDIV = div;  //时钟分频
   50   1        CLKSEL = 0x03; //选择内部 32K
   51   1      }
