    7          //========================================================================
    8          // КЏЪ§: void LCM_Inilize(LCM_InitTypeDef *LCM)
    9          // УшЪі: LCM ГѕЪМЛЏГЬађ.
   10          // ВЮЪ§: LCM: НсЙЙВЮЪ§,ЧыВЮПМLCM.hРяЕФЖЈвх.
   11          // ЗЕЛи: none.
   12          // АцБО: V1.0, 2021-06-02
   13          //========================================================================
   14          void LCM_Inilize(LCM_InitTypeDef *LCM)
   15          {
   16   1        LCMIFSTA = 0x00;
   17   1        if(LCM->LCM_Mode == MODE_M6800)   LCMIFCFG |= MODE_M6800; //LCMНгПкФЃЪНЃКM6800
   18   1        else LCMIFCFG &= ~MODE_M6800; //LCMНгПкФЃЪНЃКI8080
   19   1        
   20   1        if(LCM->LCM_Bit_Wide == BIT_WIDE_16)    LCMIFCFG |= BIT_WIDE_16;  //LCMЪ§ОнПэЖШЃК16ЮЛ
   21   1        else LCMIFCFG &= ~BIT_WIDE_16;  //LCMЪ§ОнПэЖШЃК8ЮЛ
   22   1        
   23   1        if(LCM->LCM_Setup_Time <= 7) LCMIFCFG2 = (LCMIFCFG2 & ~0x1c) | (LCM->LCM_Setup_Time << 2);  //LCMЭЈаХЪ§Он
             -НЈСЂЪБМфЃК0~7
   24   1        if(LCM->LCM_Hold_Time <= 3) LCMIFCFG2 = (LCMIFCFG2 & ~0x03) | LCM->LCM_Hold_Time; //LCMЭЈаХЪ§ОнНЈСЂЪБМфЃ
             -К0~7
   25   1        
   26   1        if(LCM->LCM_Enable == ENABLE)   LCMIFCR |= 0x80;  //ЪЙФмLCMНгПкЙІФм
   27   1        else LCMIFCR &= ~0x80;  //НћжЙLCMНгПкЙІФм
   28   1      }


