  208   1          LED8[1] = HOUR % 10;
  209   1          LED8[2] = DIS_;
  210   1          LED8[3] = MIN / 10;
  211   1          LED8[4] = MIN % 10;
  212   1          LED8[5] = DIS_;
  213   1          LED8[6] = SEC / 10;
  214   1          LED8[7] = SEC % 10;
  215   1      }
