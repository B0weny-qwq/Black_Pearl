  278          void IO_KeyScan(void)    //50ms call
  279          {
  280   1          u8  j;
  281   1      
  282   1          j = IO_KeyState1;   //дҝқеӯҳдёҠдёҖж¬ЎзҠ¶жҖҒ
  283   1      
  284   1          P0 = 0xf0;  //XдҪҺпјҢиҜ»Y
  285   1          IO_KeyDelay();
  286   1          IO_KeyState1 = P0 & 0xf0;
  287   1      
  288   1          P0 = 0x0f;  //YдҪҺпјҢиҜ»X
  289   1          IO_KeyDelay();
  290   1          IO_KeyState1 |= (P0 & 0x0f);
  291   1          IO_KeyState1 ^= 0xff;   //еҸ–еҸҚ
  292   1          
  293   1          if(j == IO_KeyState1)   //иҝһз»ӯдёӨж¬ЎиҜ»зӣёзӯү
  294   1          {
  295   2              j = IO_KeyState;
  296   2              IO_KeyState = IO_KeyState1;
  297   2              if(IO_KeyState != 0)    //жңүй”®жҢүдёӢ
  298   2              {
  299   3                  F0 = 0;
  300   3                  if(j == 0)  F0 = 1; //з¬¬дёҖж¬ЎжҢүдёӢ
  301   3                  else if(j == IO_KeyState)
  302   3                  {
  303   4                      if(++IO_KeyHoldCnt >= 20)   //1з§’еҗҺйҮҚй”®
  304   4                      {
  305   5                          IO_KeyHoldCnt = 18;
  306   5                          F0 = 1;
  307   5                      }
  308   4                  }
  309   3                  if(F0)
  310   3                  {
  311   4                      j = T_KeyTable[IO_KeyState >> 4];
  312   4                      if((j != 0) && (T_KeyTable[IO_KeyState& 0x0f] != 0)) 
C251 COMPILER V5.60.0,  APP_RTC                                                            27/04/26  00:55:18  PAGE 6   

  313   4                          KeyCode = (j - 1) * 4 + T_KeyTable[IO_KeyState & 0x0f] + 16;    //и®Ўз®—й”®з ҒпјҢ17~3
             -2
  314   4                  }
  315   3              }
  316   2              else    IO_KeyHoldCnt = 0;
  317   2          }
  318   1          P0 = 0xff;
