   43   1          /* 追加 \r\n */
   44   1          if (len < (LOG_BUF_SIZE - 2))
   45   1          {
   46   2              log_buf[len]     = '\r';
   47   2              log_buf[len + 1] = '\n';
   48   2              log_buf[len + 2] = '\0';
   49   2          }
   50   1          else
   51   1          {
   52   2              log_buf[LOG_BUF_SIZE - 3] = '\r';
   53   2              log_buf[LOG_BUF_SIZE - 2] = '\n';
   54   2              log_buf[LOG_BUF_SIZE - 1] = '\0';
   55   2          }
   56   1      
