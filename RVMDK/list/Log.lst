   67           */
   68          static void log_vtagged(u8 level, u8 *tag, u8 *fmt, va_list args)
   69          {
   70   1          u8  i;
   71   1          u8  prefix_len;
   72   1      
   73   1          /* 构建 [tag] X: 前缀 */
   74   1          log_buf[0] = '[';
   75   1          for (i = 0; tag[i] != '\0'; i++)
   76   1          {
   77   2              log_buf[i + 1] = tag[i];
   78   2          }
   79   1          log_buf[i + 1] = ']';
   80   1          log_buf[i + 2] = ' ';
   81   1          log_buf[i + 3] = level;
   82   1          log_buf[i + 4] = ':';
   83   1          log_buf[i + 5] = ' ';
   84   1          prefix_len = i + 6;
   85   1      
   86   1          /* 格式化消息到前缀之后 */
   87   1          vsprintf((char *)(log_buf + prefix_len), (const char *)fmt, args);
   88   1      
   89   1          /* 追加 \r\n 并确保不越界 */
   90   1          for (i = prefix_len; i < LOG_BUF_SIZE; i++)
   91   1          {
   92   2              if (log_buf[i] == '\0')
   93   2              {
   94   3                  if (i < (LOG_BUF_SIZE - 2))
   95   3                  {
   96   4                      log_buf[i]     = '\r';
   97   4                      log_buf[i + 1] = '\n';
   98   4                      log_buf[i + 2] = '\0';
   99   4                  }
  100   3                  else
  101   3                  {
  102   4                      log_buf[LOG_BUF_SIZE - 3] = '\r';
  103   4                      log_buf[LOG_BUF_SIZE - 2] = '\n';
  104   4                      log_buf[LOG_BUF_SIZE - 1] = '\0';
  105   4                  }
  106   3                  break;
  107   3              }
  108   2          }
  109   1      
  110   1          PrintString1(log_buf);
  111   1      }
