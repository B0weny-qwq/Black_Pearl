    7          //========================================================================
    8          // 函数: void WDT_Inilize(WDT_InitTypeDef *WDT)
    9          // 描述: 看门狗初始化程序.
   10          // 参数: WDT: 结构参数,请参考WDT.h里的定义.
   11          // 返回: none.
   12          // 版本: V1.0, 2020-09-16
   13          //========================================================================
   14          void WDT_Inilize(WDT_InitTypeDef *WDT)
   15          {
   16   1        if(WDT->WDT_Enable == ENABLE)   EN_WDT = 1; //使能看门狗
   17   1      
   18   1        WDT_PS_Set(WDT->WDT_PS);  //看门狗定时器时钟分频系数    WDT_SCALE_2,WDT_SCALE_4,WDT_SCALE_8,WDT
             -_SCALE_16,WDT_SCALE_32,WDT_SCALE_64,WDT_SCALE_128,WDT_SCALE_256
   19   1        if(WDT->WDT_IDLE_Mode == WDT_IDLE_STOP) IDL_WDT = 0;  //IDLE模式停止计数
   20   1        else                  IDL_WDT = 1;  //IDLE模式继续计数
   21   1      }
   22          
   23          /********************* 清除看门狗函数 *************************/
