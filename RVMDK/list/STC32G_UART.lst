  231          #ifdef UART1
  232          void TX1_write2buff(u8 dat) //串口1发送函数
  233          {
  234   1          #if(UART_QUEUE_MODE == 1)
                 TX1_Buffer[COM1.TX_write] = dat;  //装发送缓冲，使用队列式数据发送，一次性发送数据
             -长度不要超过缓冲区大小（COM_TXn_Lenth）
                 if(++COM1.TX_write >= COM_TX1_Lenth)  COM1.TX_write = 0;
               
                 if(COM1.B_TX_busy == 0)   //空闲
                 {  
                   COM1.B_TX_busy = 1;   //标志忙
                   TI = 1;         //触发发送中断
                 }
                   #else
  244   1          //以下是阻塞方式发送方法
  245   1        SBUF = dat;
  246   1        COM1.B_TX_busy = 1;   //标志忙
  247   1        while(COM1.B_TX_busy);
  248   1          #endif
  249   1      }
