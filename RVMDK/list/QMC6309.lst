  549   1      
  550   1          ctrl1_readback = QMC6309_ReadReg(QMC6309_REG_CONTROL_1);
  551   1          ctrl2_readback = QMC6309_ReadReg(QMC6309_REG_CONTROL_2);
  552   1          LOGI("MAG", "CTRL1=0x%02X CTRL2=0x%02X", ctrl1_readback, ctrl2_readback);
  553   1      
