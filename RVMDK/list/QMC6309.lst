  556   2              return -1;
  557   2          }
  558   1      
  559   1          if (ctrl1_readback != QMC6309_CTRL1_ACTIVE) {
  560   2              LOGW("MAG", "CTRL1 mismatch read=0x%02X exp=0x%02X",
  561   2                   ctrl1_readback, QMC6309_CTRL1_ACTIVE);
  562   2          }
  563   1          if (ctrl2_readback != QMC6309_CTRL2_INIT) {
