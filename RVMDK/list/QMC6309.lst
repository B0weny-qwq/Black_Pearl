  512   1      
  513   1          if (retry >= 3) {
  514   2              LOGE("MAG", "no device found after 3 tries");
  515   2              return -1;
  516   2          }
  517   1      
  518   1          LOGI("MAG", "selected addr=0x%02X write=0x%02X read=0x%02X",
C251 COMPILER V5.60.0,  QMC6309                                                            27/04/26  00:55:23  PAGE 9   

  521   1               qmc6309_addr,
