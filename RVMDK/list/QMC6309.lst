  530   2              LOGE("MAG", "CHIP_ID error got=0x%02X exp=0x%02X", id, QMC6309_CHIP_ID_VALUE);
  531   2              return -1;
  532   2          }
  533   1          LOGI("MAG", "CHIP_ID=0x%02X OK", id);
  534   1      
  535   1          if (QMC6309_Reset() != 0) {
  536   2              return -1;
  537   2          }
  538   1      
  539   1          if (QMC6309_WriteReg(QMC6309_REG_CONTROL_1, QMC6309_CTRL1_STANDBY) != 0) {
  540   2              return -1;
  541   2          }
  542   1          if (QMC6309_WriteReg(QMC6309_REG_CONTROL_2, QMC6309_CTRL2_INIT) != 0) {
  543   2              return -1;
  544   2          }
  545   1          if (QMC6309_WriteReg(QMC6309_REG_CONTROL_1, QMC6309_CTRL1_ACTIVE) != 0) {
  546   2              return -1;
  547   2          }
