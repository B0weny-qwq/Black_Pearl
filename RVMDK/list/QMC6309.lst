  505   2              if (QMC6309_ProbeAddr(QMC6309_I2C_ADDR_ALT) == 0) {
  506   3                  break;
  507   3              }
  508   2      
  509   2              LOGW("MAG", "addr probe fail try=%u, wait 200ms retry", retry_num);
  510   2              QMC6309_Delay_ms(200);
